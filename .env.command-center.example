# Fooocus Image Command Center
FOOOCUS_DATA_DIR=/workspace/fooocus-data
FOOOCUS_OUTPUT_DIR=/workspace/fooocus-data/outputs
FOOOCUS_DB_PATH=/workspace/fooocus-data/control-plane.sqlite3

# Compute routing
COMPUTE_MODE=auto
LOCAL_ENABLED=true
LOCAL_WORKER_URL=http://127.0.0.1:7865
RUNPOD_ENABLED=false
RUNPOD_WORKER_URL=
RUNPOD_API_KEY=

# Safe RunPod provisioning defaults
RUNPOD_AUTO_PROVISION=false
RUNPOD_REQUIRE_APPROVAL=true
RUNPOD_MAX_HOURLY_COST=1.00
RUNPOD_MAX_SESSION_COST=5.00
RUNPOD_IDLE_SHUTDOWN_MINUTES=15
RUNPOD_ALLOWED_GPUS=RTX_4090,L40S,A40,A100
